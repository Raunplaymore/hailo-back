# Copy to .env on the NAS. Do not commit the real token.
# Do not set the Tailscale IP here. DSM runs Tailscale in userspace mode;
# Tailscale Serve forwards the tailnet port to this loopback listener.
STORAGE_BIND_HOST=127.0.0.1
STORAGE_API_PORT=18080
ARCHIVE_TOKEN=replace-with-a-long-random-token
MAX_UPLOAD_BYTES=4294967296
# Mobile library login. Keep these values only in the NAS .env file.
LIBRARY_PASSWORD=replace-with-a-long-unique-password
LIBRARY_SESSION_SECRET=replace-with-a-long-random-session-secret
# Set false only for local HTTP development. Tailscale HTTPS production must stay true.
LIBRARY_COOKIE_SECURE=true
